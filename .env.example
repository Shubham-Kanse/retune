# Retune environment template (Charter 20 Epic 02 + 03).
#
# 1. Copy this file: `cp .env.example .env`
# 2. Fill in REQUIRED values. OPTIONAL sections can be skipped in dev.
# 3. NEVER commit a `.env` file — `.gitignore` blocks it.
#
# This template mirrors `apps/web/src/lib/env.ts`. If you add a new
# env var to the Zod schema there, add it here too. CI verifies parity.

# ──────────────────────────────────────────────────────────────────
# REQUIRED — Supabase (auth + DB)
# ──────────────────────────────────────────────────────────────────
# From Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# From Supabase Dashboard → Project Settings → Database
# Use the Transaction Pooler URL (port 6543) for serverless / Vercel.
RETUNE_DATABASE_URL=postgresql://postgres.ref:password@aws-0-region.pooler.supabase.com:6543/postgres
RETUNE_DB_KIND=postgres
RETUNE_PERSIST=postgres

# ──────────────────────────────────────────────────────────────────
# REQUIRED — Application URLs
# ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8787

# ──────────────────────────────────────────────────────────────────
# REQUIRED — AI provider (set the one matching AI_PROVIDER)
# ──────────────────────────────────────────────────────────────────
AI_PROVIDER=anthropic
OPENAI_API_KEY=
ANTHROPIC_API_KEY=sk-ant-...

# ──────────────────────────────────────────────────────────────────
# REQUIRED — Platform secrets
# ──────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_SECRET=replace-with-32-plus-character-random-string

# Generate with: openssl rand -base64 32
# Required in production (Charter 01 Epic 03)
RETUNE_INTERNAL_API_KEY=
RETUNE_INTERNAL_GENERATION_ACCESS_SECRET=

# Optional preview-mode signing secret
RETUNE_PREVIEW_SECRET=

# ──────────────────────────────────────────────────────────────────
# REQUIRED — Email (password reset, signup verification)
# ──────────────────────────────────────────────────────────────────
SMTP_HOST=mail.privateemail.com
SMTP_PORT=465
SMTP_USER=hello@retuned.cv
SMTP_PASS=your-mailbox-password
SMTP_FROM=hello@retuned.cv

# ──────────────────────────────────────────────────────────────────
# OPTIONAL — Temporal (REQUIRED in production per Charter 04 Epic 01)
# ──────────────────────────────────────────────────────────────────
RETUNE_TEMPORAL=0
# RETUNE_TEMPORAL_ADDRESS=temporal.example.com:7233
# RETUNE_TEMPORAL_NAMESPACE=retune-prod

# ──────────────────────────────────────────────────────────────────
# OPTIONAL — ML service
# ──────────────────────────────────────────────────────────────────
RETUNE_ML_USE_STUBS=true
RETUNE_ML_TRANSPORT=http
# RETUNE_ML_BASE_URL=http://localhost:8000
# RETUNE_ML_GRPC_BASE=http://localhost:9000
RETUNE_ML_DISABLE=0

# ──────────────────────────────────────────────────────────────────
# OPTIONAL — Operational toggles
# ──────────────────────────────────────────────────────────────────
NODE_ENV=development
ENABLE_BILLING=false
ENABLE_CRON=1
FREE_GENERATION_LIMIT=2
RETUNE_API_CORS=*
ADMIN_SECRET=

# ──────────────────────────────────────────────────────────────────
# OPTIONAL — Model overrides (defaults baked into agent)
# ──────────────────────────────────────────────────────────────────
# AGENT_MODEL=claude-sonnet-4-5-20250929
# AGENT_MODEL_FAST=claude-haiku-4-5-20251001
# AGENT_MODEL_FRONTIER=claude-opus-4-5-20250929
# ONBOARDING_EXTRACT_MODEL=
# ONBOARDING_ROUTER_MODEL=
# ONBOARDING_MODEL=

# ──────────────────────────────────────────────────────────────────
# OPTIONAL — Charter 03 Stripe billing
# ──────────────────────────────────────────────────────────────────
# Required to activate billing routes:
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_PRO_MONTHLY=price_...
# STRIPE_PRICE_MAX_MONTHLY=price_...

# ──────────────────────────────────────────────────────────────────
# OPTIONAL — Charter 05 observability
# ──────────────────────────────────────────────────────────────────
# Sentry — server-side error tracking
# SENTRY_DSN=https://...@o0.ingest.sentry.io/0
# NEXT_PUBLIC_SENTRY_DSN=https://...@o0.ingest.sentry.io/0
# SENTRY_AUTH_TOKEN=  # CI source-map upload only

# OpenTelemetry — distributed tracing
# OTEL_EXPORTER_OTLP_ENDPOINT=https://api.honeycomb.io/v1/traces
# OTEL_EXPORTER_OTLP_HEADERS=x-honeycomb-team=YOUR_KEY
OTEL_SERVICE_NAME=retune-web

# ──────────────────────────────────────────────────────────────────
# OPTIONAL — Charter 15 growth analytics
# ──────────────────────────────────────────────────────────────────
# PostHog (EU-hosted by default)
# NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# ──────────────────────────────────────────────────────────────────
# DEV ONLY — E2E test bypass (NEVER set in production)
# ──────────────────────────────────────────────────────────────────
# E2E_AUTH_BYPASS=1
# E2E_AUTH_USER_ID=00000000-0000-4000-8000-000000000000
# E2E_AUTH_EMAIL=test@example.com
# E2E_AUTH_NAME=Test User

# ──────────────────────────────────────────────────────────────────
# Billing credits (defaults shown; override per-environment)
# ──────────────────────────────────────────────────────────────────
# FREE_PLAN_CREDITS=30
# PRO_PLAN_CREDITS=500
# MAX_PLAN_CREDITS=1500
# CREDIT_COST_GENERATION=10
# CREDIT_COST_REFINEMENT=1
