# RetuneAI — environment template (v2.0; see technical-2.0 §18.3).
#
# Copy this file to `.env` at the repo root. Values marked REQUIRED must be
# set before `pnpm dev` boots; OPTIONAL values fall back to sensible
# defaults documented below.

# ─── Auth (REQUIRED) ─────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-32-char-string-minimum

# ─── LLM provider (REQUIRED) ─────────────────────────────────────────────────
# AI_PROVIDER selects which provider the cognitive cycle calls at runtime.
# Both providers are wired; switching is a one-line env change.
#   anthropic — Sonnet smart, Haiku fast, Opus frontier
#   openai    — gpt-4o smart, gpt-4o-mini fast, gpt-5 frontier
AI_PROVIDER=anthropic

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Model tier overrides (optional — defaults shown). Each tier is a string
# the SDK will accept as a model name.
# AGENT_MODEL=claude-sonnet-4-6        # smart tier (cognitive cycle)
# AGENT_MODEL_FAST=claude-haiku-4-5    # fast tier (critic ensemble, onboarding chat)
# AGENT_MODEL_FRONTIER=claude-opus-4-1 # frontier escalation (CriticEnsemble divergence)

# Legacy openai-agents pipeline overrides (only when AI_PROVIDER=openai AND
# the legacy resume generator is in use; deprecated in v2.1).
# OPENAI_SMART_MODEL=gpt-4.1
# OPENAI_FAST_MODEL=gpt-4.1-mini
# OPENAI_SEARCH_MODEL=gpt-4.1

# ─── Persistence (Postgres-only) ─────────────────────────────────────────────
# `RETUNE_DB_KIND=pglite`    — in-process WASM Postgres (zero-config dev/CI)
# `RETUNE_DB_KIND=postgres`  — real Postgres via RETUNE_DATABASE_URL
# Auto-detect: if RETUNE_DATABASE_URL or DATABASE_URL is set, kind=postgres.
RETUNE_DB_KIND=pglite
# RETUNE_DATABASE_URL=postgresql://retune:retune@localhost:5432/retune
# RETUNE_PGLITE_DATADIR=./data/pglite   # persist pglite across runs (optional)
#
# Cognitive workbench durability: same backend as @retune/db.
# RETUNE_PERSIST={off|pglite|postgres}
RETUNE_PERSIST=pglite

# ─── Temporal (durable workflow engine) ──────────────────────────────────────
# RETUNE_TEMPORAL=0 — in-process orchestrator (zero-config dev default)
# RETUNE_TEMPORAL=1 — connect to a real Temporal cluster
RETUNE_TEMPORAL=0
RETUNE_TEMPORAL_ADDRESS=localhost:7233
RETUNE_TEMPORAL_NAMESPACE=default

# ─── ML server ───────────────────────────────────────────────────────────────
# Used by JdSpanExtractor, DiscourseClassifier, CulturalCalibrator. The
# stub mode is sufficient for `pnpm test` and dev runs that don't exercise
# real DeBERTa/GLiNER/BGE models.
RETUNE_ML_BASE_URL=http://localhost:8000
RETUNE_ML_HTTP_BASE=http://localhost:8000
RETUNE_ML_GRPC_BASE=http://localhost:50051
RETUNE_ML_USE_STUBS=true
# RETUNE_ML_DISABLE=1               # short-circuit ML calls entirely (dev only)

# ─── Auth & app URL (apps/web) ───────────────────────────────────────────────
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── API ports ───────────────────────────────────────────────────────────────
# API_PORT=8787
# WEB_PORT=3000
# ML_PORT=8000

# ─── Web → cognitive API binding ────────────────────────────────────────────
# Base URL the Next.js frontend uses to call the Hono cognitive API.
# Defaults to http://localhost:8787 (the API's default port). Set this in
# production to the public URL of @retune/api.
NEXT_PUBLIC_API_URL=http://localhost:8787


# Optional: tighten CORS on @retune/api in production. Leave unset (defaults
# to "*") for local dev. Set to the exact origin of apps/web in prod.
# RETUNE_API_CORS=https://retune.so
