# ─── Supabase (REQUIRED) ─────────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Database (REQUIRED) ─────────────────────────────────────────────────────
# Get from: Supabase Dashboard → Project Settings → Database → Connection string (Transaction pooler, port 6543)
RETUNE_DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-region.pooler.supabase.com:6543/postgres
RETUNE_DB_KIND=postgres

# ─── App URL (REQUIRED) ──────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
# In production set to your Vercel domain, e.g. https://retune.vercel.app
NEXT_PUBLIC_API_URL=http://localhost:4000
# In production set to same as NEXT_PUBLIC_APP_URL if API is co-located

# ─── AI Provider (REQUIRED — pick one) ───────────────────────────────────────
AI_PROVIDER=openai
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ─── Email (REQUIRED for password reset & verification) ──────────────────────
# Namecheap Private Email SMTP
SMTP_HOST=mail.privateemail.com
SMTP_PORT=465
SMTP_USER=hello@retuned.cv
SMTP_PASS=your-mailbox-password
SMTP_FROM=hello@retuned.cv

# ─── ML Service (OPTIONAL) ───────────────────────────────────────────────────
# Set to true to skip real ML calls (safe for dev and Vercel deployments)
RETUNE_ML_USE_STUBS=true
# Only needed if you run the ML service (apps/ml) separately
# RETUNE_ML_BASE_URL=http://localhost:8000

# ─── Billing credits (OPTIONAL — defaults shown) ─────────────────────────────
# FREE_PLAN_CREDITS=30
# PRO_PLAN_CREDITS=500
# MAX_PLAN_CREDITS=1500
# CREDIT_COST_GENERATION=10
# CREDIT_COST_REFINEMENT=1

# ─── API CORS (OPTIONAL) ─────────────────────────────────────────────────────
# Tighten to your domain in production, e.g. https://retune.vercel.app
RETUNE_API_CORS=*
