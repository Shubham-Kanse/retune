{
  "name": "retune",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "turbo dev",
    "dev:all": "concurrently -n web,api,worker -c blue,green,yellow \"pnpm --filter @retune/web dev\" \"pnpm --filter @retune/api dev\" \"pnpm --filter @retune/worker dev\"",
    "dev:lite": "turbo dev --filter @retune/api --filter @retune/web",
    "dev:infra": "docker compose -f infra/compose/dev.yml up",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d postgres",
    "startup:selfcheck": "pnpm --filter @retune/web startup:selfcheck && pnpm --filter @retune/api startup:selfcheck && pnpm --filter @retune/worker startup:selfcheck",
    "db:audit:schema": "pnpm -C apps/web exec node ../../tools/db/schema-audit.cjs",
    "build": "turbo build",
    "postinstall": "node scripts/copy-pdf-worker.mjs",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "test:eval": "pnpm --filter @retune/eval eval",
    "db:migrate": "pnpm --filter @retune/db db:migrate",
    "db:studio": "pnpm --filter @retune/db db:studio"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "concurrently": "^9.0.0",
    "tsx": "^4.21.0",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "@biomejs/biome", "esbuild", "sharp"],
    "overrides": {
      "drizzle-orm": "0.38.4"
    }
  }
}
