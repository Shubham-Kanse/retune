{
  "name": "@retune/eval",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./canonical": "./src/canonical/loader.ts",
    "./metrics": "./src/metrics/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
