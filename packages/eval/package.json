  },
  "dependencies": {
    "@retune/agent": "workspace:*",
    "@retune/types": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@retune/tsconfig": "workspace:*",
    "@types/node": "^22.10.10",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3"
  }
}
