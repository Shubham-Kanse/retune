{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Retune design token source of truth (Charter 10 Epic 02). Three-layer architecture: primitive → semantic → component. The semantic layer maps to CSS custom properties in apps/web/src/styles/globals.css. The cognitive layer maps to packages/ui/src/tokens/cognitive-palette.ts.",

  "primitive": {
    "$description": "Raw values — not used directly in components.",
    "color": {
      "white": { "$value": "hsl(0 0% 100%)", "$type": "color" },
      "black": { "$value": "hsl(240 10% 3.9%)", "$type": "color" },
      "near-black-warm": { "$value": "hsl(50 2% 9%)", "$type": "color" },
      "near-black-warm-dark": { "$value": "hsl(50 2% 7%)", "$type": "color" },
      "near-black-warm-popover": { "$value": "hsl(50 2% 11%)", "$type": "color" },
      "gray-50": { "$value": "hsl(0 0% 98%)", "$type": "color" },
      "gray-100": { "$value": "hsl(240 4.8% 95.9%)", "$type": "color" },
      "gray-200": { "$value": "hsl(240 5.9% 90%)", "$type": "color" },
      "gray-300": { "$value": "hsl(240 3.7% 15.9%)", "$type": "color" },
      "gray-400": { "$value": "hsl(240 3.8% 46.1%)", "$type": "color" },
      "gray-500": { "$value": "hsl(240 5% 64.9%)", "$type": "color" },
      "gray-600": { "$value": "hsl(240 4.9% 83.9%)", "$type": "color" },
      "gray-700": { "$value": "hsl(240 5.3% 26.1%)", "$type": "color" },
      "gray-800": { "$value": "hsl(240 5.9% 10%)", "$type": "color" },
      "red-destructive-light": { "$value": "hsl(0 84.2% 60.2%)", "$type": "color" },
      "red-destructive-dark": { "$value": "hsl(0 62.8% 30.6%)", "$type": "color" },
      "blue-ring": { "$value": "hsl(217.2 91.2% 59.8%)", "$type": "color" },
      "blue-sidebar-primary": { "$value": "hsl(224.3 76.3% 48%)", "$type": "color" },
      "sidebar-border-light": { "$value": "hsl(220 13% 91%)", "$type": "color" }
    },
    "radius": {
      "base": { "$value": "0.5rem", "$type": "dimension" }
    }
  },

  "semantic": {
    "$description": "Semantic tokens — these map to CSS custom properties. Light mode values are the default; dark mode overrides are documented in the dark section.",
    "color": {
      "background": {
        "$value": "var(--background)",
        "$type": "color",
        "light": { "$value": "hsl(0 0% 100%)", "$type": "color" },
        "dark": { "$value": "hsl(50 2% 9%)", "$type": "color" }
      },
      "foreground": {
        "$value": "var(--foreground)",
        "$type": "color",
        "light": { "$value": "hsl(240 10% 3.9%)", "$type": "color" },
        "dark": { "$value": "hsl(0 0% 98%)", "$type": "color" }
      },
      "card": {
        "$value": "var(--card)",
        "$type": "color",
        "light": { "$value": "hsl(0 0% 100%)", "$type": "color" },
        "dark": { "$value": "hsl(50 2% 9%)", "$type": "color" }
      },
      "card-foreground": {
        "$value": "var(--card-foreground)",
        "$type": "color",
        "light": { "$value": "hsl(240 10% 3.9%)", "$type": "color" },
        "dark": { "$value": "hsl(0 0% 98%)", "$type": "color" }
      },
      "popover": {
        "$value": "var(--popover)",
        "$type": "color",
        "light": { "$value": "hsl(0 0% 100%)", "$type": "color" },
        "dark": { "$value": "hsl(50 2% 11%)", "$type": "color" }
      },
      "popover-foreground": {
        "$value": "var(--popover-foreground)",
        "$type": "color",
        "light": { "$value": "hsl(240 10% 3.9%)", "$type": "color" },
        "dark": { "$value": "hsl(0 0% 98%)", "$type": "color" }
      },
      "primary": {
        "$value": "var(--primary)",
        "$type": "color",
        "light": { "$value": "hsl(240 5.9% 10%)", "$type": "color" },
        "dark": { "$value": "hsl(0 0% 98%)", "$type": "color" }
      },
      "primary-foreground": {
        "$value": "var(--primary-foreground)",
        "$type": "color",
        "light": { "$value": "hsl(0 0% 98%)", "$type": "color" },
        "dark": { "$value": "hsl(240 5.9% 10%)", "$type": "color" }
      },
      "secondary": {
        "$value": "var(--secondary)",
        "$type": "color",
        "light": { "$value": "hsl(240 4.8% 95.9%)", "$type": "color" },
        "dark": { "$value": "hsl(240 3.7% 15.9%)", "$type": "color" }
      },
      "secondary-foreground": {
        "$value": "var(--secondary-foreground)",
        "$type": "color",
        "light": { "$value": "hsl(240 5.9% 10%)", "$type": "color" },
        "dark": { "$value": "hsl(0 0% 98%)", "$type": "color" }
      },
      "muted": {
        "$value": "var(--muted)",
        "$type": "color",
        "light": { "$value": "hsl(240 4.8% 95.9%)", "$type": "color" },
        "dark": { "$value": "hsl(240 3.7% 15.9%)", "$type": "color" }
      },
      "muted-foreground": {
        "$value": "var(--muted-foreground)",
        "$type": "color",
        "light": { "$value": "hsl(240 3.8% 46.1%)", "$type": "color" },
        "dark": { "$value": "hsl(240 5% 64.9%)", "$type": "color" }
      },
      "accent": {
        "$value": "var(--accent)",
        "$type": "color",
        "light": { "$value": "hsl(240 4.8% 95.9%)", "$type": "color" },
        "dark": { "$value": "hsl(240 3.7% 15.9%)", "$type": "color" }
      },
      "accent-foreground": {
        "$value": "var(--accent-foreground)",
        "$type": "color",
        "light": { "$value": "hsl(240 5.9% 10%)", "$type": "color" },
        "dark": { "$value": "hsl(0 0% 98%)", "$type": "color" }
      },
      "destructive": {
        "$value": "var(--destructive)",
        "$type": "color",
        "light": { "$value": "hsl(0 84.2% 60.2%)", "$type": "color" },
        "dark": { "$value": "hsl(0 62.8% 30.6%)", "$type": "color" }
      },
      "destructive-foreground": {
        "$value": "var(--destructive-foreground)",
        "$type": "color",
        "light": { "$value": "hsl(0 0% 98%)", "$type": "color" },
        "dark": { "$value": "hsl(0 0% 98%)", "$type": "color" }
      },
      "border": {
        "$value": "var(--border)",
        "$type": "color",
        "light": { "$value": "hsl(240 5.9% 90%)", "$type": "color" },
        "dark": { "$value": "hsl(240 3.7% 15.9%)", "$type": "color" }
      },
      "input": {
        "$value": "var(--input)",
        "$type": "color",
        "light": { "$value": "hsl(240 5.9% 90%)", "$type": "color" },
        "dark": { "$value": "hsl(240 3.7% 15.9%)", "$type": "color" }
      },
      "ring": {
        "$value": "var(--ring)",
        "$type": "color",
        "light": { "$value": "hsl(240 10% 3.9%)", "$type": "color" },
        "dark": { "$value": "hsl(240 4.9% 83.9%)", "$type": "color" }
      },
      "sidebar": {
        "$value": "var(--sidebar)",
        "$type": "color",
        "light": { "$value": "hsl(0 0% 100%)", "$type": "color" },
        "dark": { "$value": "hsl(50 2% 7%)", "$type": "color" }
      },
      "sidebar-foreground": {
        "$value": "var(--sidebar-foreground)",
        "$type": "color",
        "light": { "$value": "hsl(240 5.3% 26.1%)", "$type": "color" },
        "dark": { "$value": "hsl(240 4.8% 95.9%)", "$type": "color" }
      },
      "sidebar-primary": {
        "$value": "var(--sidebar-primary)",
        "$type": "color",
        "light": { "$value": "hsl(240 5.9% 10%)", "$type": "color" },
        "dark": { "$value": "hsl(224.3 76.3% 48%)", "$type": "color" }
      },
      "sidebar-primary-foreground": {
        "$value": "var(--sidebar-primary-foreground)",
        "$type": "color",
        "light": { "$value": "hsl(0 0% 98%)", "$type": "color" },
        "dark": { "$value": "hsl(0 0% 100%)", "$type": "color" }
      },
      "sidebar-accent": {
        "$value": "var(--sidebar-accent)",
        "$type": "color",
        "light": { "$value": "hsl(240 4.8% 95.9%)", "$type": "color" },
        "dark": { "$value": "hsl(240 3.7% 15.9%)", "$type": "color" }
      },
      "sidebar-accent-foreground": {
        "$value": "var(--sidebar-accent-foreground)",
        "$type": "color",
        "light": { "$value": "hsl(240 5.9% 10%)", "$type": "color" },
        "dark": { "$value": "hsl(240 4.8% 95.9%)", "$type": "color" }
      },
      "sidebar-border": {
        "$value": "var(--sidebar-border)",
        "$type": "color",
        "light": { "$value": "hsl(220 13% 91%)", "$type": "color" },
        "dark": { "$value": "hsl(240 3.7% 15.9%)", "$type": "color" }
      },
      "sidebar-ring": {
        "$value": "var(--sidebar-ring)",
        "$type": "color",
        "light": { "$value": "hsl(217.2 91.2% 59.8%)", "$type": "color" },
        "dark": { "$value": "hsl(217.2 91.2% 59.8%)", "$type": "color" }
      }
    },
    "radius": {
      "base": { "$value": "0.5rem", "$type": "dimension" },
      "sm": { "$value": "calc(0.5rem - 4px)", "$type": "dimension" },
      "md": { "$value": "calc(0.5rem - 2px)", "$type": "dimension" },
      "lg": { "$value": "0.5rem", "$type": "dimension" },
      "xl": { "$value": "calc(0.5rem + 4px)", "$type": "dimension" }
    },
    "font": {
      "sans": { "$value": "var(--font-inter), ui-sans-serif, system-ui, sans-serif", "$type": "fontFamily" },
      "mono": { "$value": "var(--font-geist-mono), ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace", "$type": "fontFamily" }
    }
  },

  "cognitive": {
    "$description": "Pipeline-state and emotion tokens. Source of truth: packages/ui/src/tokens/cognitive-palette.ts. All values in oklch for perceptual uniformity.",
    "state": {
      "pending": { "$value": "oklch(0.65 0.02 250)", "$type": "color", "$description": "Step/goal is waiting to execute" },
      "active": { "$value": "oklch(0.75 0.15 200)", "$type": "color", "$description": "Currently executing" },
      "satisfied": { "$value": "oklch(0.72 0.15 155)", "$type": "color", "$description": "Successfully completed" },
      "abandoned": { "$value": "oklch(0.55 0.03 30)", "$type": "color", "$description": "Abandoned or skipped" },
      "blocked": { "$value": "oklch(0.65 0.2 25)", "$type": "color", "$description": "Error or blocked" },
      "conflict": { "$value": "oklch(0.7 0.18 50)", "$type": "color", "$description": "Conflict detected" }
    },
    "confidence": {
      "high": { "$value": "oklch(0.72 0.15 155)", "$type": "color" },
      "mid": { "$value": "oklch(0.75 0.12 80)", "$type": "color" },
      "low": { "$value": "oklch(0.65 0.18 25)", "$type": "color" }
    },
    "emotion": {
      "neutral": { "$value": "oklch(0.6 0.02 250)", "$type": "color" },
      "confident": { "$value": "oklch(0.72 0.12 155)", "$type": "color" },
      "excited": { "$value": "oklch(0.75 0.15 90)", "$type": "color" },
      "hopeful": { "$value": "oklch(0.7 0.1 140)", "$type": "color" },
      "determined": { "$value": "oklch(0.68 0.12 200)", "$type": "color" },
      "anxious": { "$value": "oklch(0.65 0.15 50)", "$type": "color" },
      "frustrated": { "$value": "oklch(0.6 0.18 25)", "$type": "color" },
      "overwhelmed": { "$value": "oklch(0.55 0.12 300)", "$type": "color" }
    },
    "misc": {
      "cost": { "$value": "oklch(0.7 0.1 280)", "$type": "color", "$description": "Cost indicator" },
      "narrative": { "$value": "oklch(0.6 0.02 260)", "$type": "color", "$description": "Narrative/explanation text" }
    }
  }
}
